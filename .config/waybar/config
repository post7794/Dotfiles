{
    "modules-left": ["custom/power", "hyprland/workspaces", "hyprland/taskbar"],
    // "modules-center": [],
    "modules-right": ["tray", "bluetooth", "network", "battery", "pulseaudio", "clock"],

    "custom/power": {
        "format" : "έφα ",
        "tooltip": false,
        "on-click": "wlogout -b 5",
    },

    "hyprland/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "warp-on-scroll": false,
        "format": "{name}",
        "cursor": true,
    },

    "hyprland/taskbar": {
        "format": "{icon}",
        "icon-size": 16,
        "spacing": 4,
        "tooltip-format": "{title}",
        "on-click": "activate",
        "on-click-middle": "close",
        "ignore-list": ["waybar"],
        "sort-by-app-id": true
    },

    "tray": {
        "icon-size": 20,
        "spacing": 10,
        "cursor": true,
    },

    "bluetooth": {
        "format": " ≤░Γψ ",
        "format-disabled": " ≤░Γ▓ ",
        "format-connected": " ≤░Γ▒ ",
        "on-click": "blueman-manager",
    },

    "network": {
        "format-wifi": "ΎΘτ  {essid}",
        "format-ethernet": "Ό╝Κ  Ethernet",
        "format-linked": "ΎΒη  Linked (No IP)",
        "format-disconnected": "ΎΒ▒  Disconnected",
        "tooltip": false,
    },

    "battery": {
        "states": {
            "good": 85,
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}%",
        "format-full": "{icon} {capacity}%",
        "format-plugged": "ΎΔπ {capacity}%",
        "format-charging": "ΎΔπ {capacity}%",
        "format-alt": "{icon} {capacity}%",
        "format-icons": ["ΎΚΕ ", "ΎΚΔ ", "ΎΚΓ ", "ΎΚΒ ", "ΎΚΑ "],
        "tooltip-format": "{time}",
        "cursor": false,
    },

    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": "ΎΣο  {volume}%",
        "format-bluetooth": "ΎΛΦ {volume}%",
        "format-bluetooth-muted": "ΎΣο  {volume}%",
        "format-icons": {
            "headphone": "ΎΑξ ",
            "headset": "ΎΑξ ",
            "default": ["ΎΑρ "],
        },
        "on-click": "pavucontrol",
    },

    "clock": {
        "format": "{:%a %d/%m/%Y ~ %H:%M}",
        "tooltip-format": "<span size='15000'><tt>{calendar}</tt></span>",
        "calendar": {
            "mode": "month",
            "format": {
                "months": "<span color='#F5C2E7'><b>{}</b></span>",
                "weekdays": "<span color='#89B4FA'><b>{}</b></span>",
                "days": "<span color='#CDD6F4'><b>{}</b></span>",
                "today": "<span color='#F9E2AF'><b>{}</b></span>",
            }
        },
        "on-click": "swaync-client -t -sw",
    }
}
